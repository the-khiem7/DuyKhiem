---
import type { CollectionEntry } from 'astro:content'

import { getBlogCollection } from 'astro-pure/server'
import config from '@/site-config'
import { getLocalizedTagsWithCount, getLocalizedPostsByTag } from '@/utils/blog-i18n'
import { DEFAULT_LOCALE } from '@/utils/i18n'

export const prerender = true

export async function getStaticPaths() {
  const allPosts = (await getBlogCollection()) as CollectionEntry<'blog'>[]
  const tags = getLocalizedTagsWithCount(allPosts, DEFAULT_LOCALE).map(([tag]) => tag)

  return tags.flatMap((tag) => {
    const taggedPosts = getLocalizedPostsByTag(allPosts, DEFAULT_LOCALE, tag)
    const pageCount = Math.max(1, Math.ceil(taggedPosts.length / (config.content.blogPageSize || 8)))

    return Array.from({ length: pageCount }, (_, index) => ({
      params: {
        tag,
        page: index === 0 ? undefined : `${index + 1}`
      }
    }))
  })
}

return Astro.redirect(`/en${Astro.url.pathname}`, 301)
