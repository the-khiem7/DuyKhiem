---
import type { CollectionEntry } from 'astro:content'

import { getBlogCollection } from 'astro-pure/server'
import config from '@/site-config'
import { getLocalizedBlogEntries } from '@/utils/blog-i18n'
import { DEFAULT_LOCALE } from '@/utils/i18n'

export const prerender = true

export async function getStaticPaths() {
  const posts = getLocalizedBlogEntries(
    (await getBlogCollection()) as CollectionEntry<'blog'>[],
    DEFAULT_LOCALE
  )
  const pageCount = Math.max(1, Math.ceil(posts.length / (config.content.blogPageSize || 8)))

  return Array.from({ length: pageCount }, (_, index) => ({
    params: { page: index === 0 ? undefined : `${index + 1}` }
  }))
}

return Astro.redirect(
  Astro.url.pathname === '/blog' ? '/en/blog' : `/en${Astro.url.pathname}`,
  301
)
