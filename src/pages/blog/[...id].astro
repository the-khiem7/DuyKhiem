---
import type { CollectionEntry } from 'astro:content'

import { getBlogBaseSlug, getBlogEntryLocale } from '@/utils/blog-i18n'
import { getBlogCollection } from 'astro-pure/server'

export const prerender = true

export async function getStaticPaths() {
  const posts = (await getBlogCollection()) as CollectionEntry<'blog'>[]

  return posts.map((post) => ({
    params: { id: post.id },
    props: {
      target: `/${getBlogEntryLocale(post)}/blog/${getBlogBaseSlug(post)}`
    }
  }))
}

return Astro.redirect((Astro.props as { target: string }).target, 301)
