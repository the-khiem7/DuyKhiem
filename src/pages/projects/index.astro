---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'flagship-projects', text: 'Flagship Projects' },
  { depth: 2, slug: 'supporting-projects', text: 'Supporting Projects' },
  { depth: 2, slug: 'what-these-projects-show', text: 'What These Projects Show' }
]
---

<PageLayout title='Projects' {headings} view>
  <p>
    My strongest projects sit around workflow-heavy systems, distributed backends, cloud-native
    infrastructure, and applied AI. I care most about projects where backend architecture directly
    shapes operations, reliability, and user trust.
  </p>
  <p>
    If you want to discuss a backend, cloud, or product engineering opportunity, feel free to reach
    out through GitHub or LinkedIn.
  </p>
  <Button title='View my GitHub' class='w-fit' href='https://github.com/the-khiem7' target='_blank' />

  <h2 id='flagship-projects'>Flagship Projects</h2>
  <ProjectSection
    projects={[
      {
        name: 'SnakeAid',
        description:
          'AI-powered healthcare platform for snakebite first aid, rescue coordination, snake identification, and expert support.',
        links: [{ type: 'github', href: 'https://github.com/the-khiem7' }]
      },
      {
        name: 'AlohaMarket',
        description:
          'Event-driven marketplace backend with 8 microservices, Kafka-based workflows, YARP gateway, Keycloak auth, SignalR, and observability.',
        links: [{ type: 'github', href: 'https://github.com/AlohaMarket/AlohaMarket.Aspire' }]
      },
      {
        name: 'EzyFix',
        description:
          'Home-repair marketplace backend with request lifecycle management, escrow-style payments, technician payouts, dispute handling, and real-time updates.',
        links: [{ type: 'github', href: 'https://github.com/EzyFixApp/EzyFix.aspnet' }]
      },
      {
        name: 'AWS Clickstream Analytics Platform',
        description:
          'Serverless analytics pipeline built with S3, Lambda, EventBridge, PostgreSQL, and R Shiny for clickstream ingestion and dashboarding.',
        links: [{ type: 'github', href: 'https://github.com/SBW-Cloudworks' }]
      }
    ]}
  />

  <h2 id='supporting-projects'>Supporting Projects</h2>
  <ProjectSection
    projects={[
      {
        name: 'CellphoneZ',
        description:
          'Flutter commerce app covering browse, cart, checkout, payment flows, store locator, and admin tooling with Supabase-based delivery.',
        links: [
          { type: 'github', href: 'https://github.com/FirstAndroidJourney/Flutter-CellphoneZ' }
        ]
      },
      {
        name: 'Claim Request System',
        description:
          'Enterprise-style financial approval workflow system centered on claim routing, reminders, finance processing, and auditability.',
        links: [
          {
            type: 'github',
            href: 'https://github.com/ClaimRequestSystem/ClaimRequestSystem.ASPNET'
          }
        ]
      },
      {
        name: 'VitaFlow',
        description:
          'Blood donation support system with donor, recipient, staff, and admin workflows built on .NET 8, Razor Pages, EF Core, and SQL Server.',
        links: [{ type: 'github', href: 'https://github.com/the-khiem7' }]
      },
      {
        name: 'TTK Piano Center',
        description:
          'Java web application for course management, enrollment, cart behavior, and admin operations using JSP/Servlet, JDBC, and SQL Server.',
        links: [{ type: 'site', href: 'https://ttk-piano.vercel.app' }]
      }
    ]}
  />

  <h2 id='what-these-projects-show'>What These Projects Show</h2>
  <ul>
    <li>I am strongest when the problem involves workflows, backend architecture, and operational complexity.</li>
    <li>I can work across multiple service boundaries instead of staying inside a single API or UI layer.</li>
    <li>I am comfortable mixing product delivery with infrastructure, integrations, data flows, and AI features.</li>
    <li>I prefer projects where technical decisions have visible impact on reliability, transparency, and maintainability.</li>
  </ul>
</PageLayout>
