---
import { type CollectionEntry, render } from 'astro:content'

import { MediumZoom } from 'astro-pure/advanced'
import { TOC } from 'astro-pure/components/pages'
import { getBlogCollection } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'
import ProjectsContents from '@/components/projects/ProjectsContents.astro'
import { SUPPORTED_LOCALES, type SiteLocale, withLocalePath } from '@/utils/i18n'

export const prerender = true

export async function getStaticPaths() {
  const projects = (await getBlogCollection('projects')) as CollectionEntry<'projects'>[]
  return SUPPORTED_LOCALES.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, id: project.id },
      props: { project, locale: lang }
    }))
  )
}

type Props = {
  locale: SiteLocale
  project: CollectionEntry<'projects'>
}

const { locale, project } = Astro.props
const { Content, headings } = await render(project)
const { description, title, duration, links, role, stack } = project.data
---

<PageLayout meta={{ description, title }} back={withLocalePath(locale, '/projects')} locale={locale}>
  <Fragment slot='sidebar'>
    {!!headings.length && <TOC {headings} />}
    <ProjectsContents class='projects-toc block mt-3' locale={locale} />
  </Fragment>

  <Fragment slot='header'>
    <h1 class='text-2xl font-medium sm:mb-2 sm:text-3xl'>{title}</h1>
    <div class='mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
      {role && <span>{role}</span>}
      {duration && <span>{duration}</span>}
    </div>
    <blockquote class='mt-3 text-sm italic text-muted-foreground'>
      <q>{description}</q>
    </blockquote>
    {
      !!stack.length && (
        <div class='mt-4 flex flex-wrap gap-2'>
          {stack.map((item) => (
            <span class='rounded-full bg-muted px-3 py-1 text-xs text-muted-foreground'>{item}</span>
          ))}
        </div>
      )
    }
    {
      !!links.length && (
        <div class='mt-4 flex flex-wrap gap-3'>
          {links.map((link) => (
            <Button
              title={link.label ?? `Open ${link.type}`}
              href={link.href}
              class='w-fit'
              target='_blank'
            />
          ))}
        </div>
      )
    }
  </Fragment>

  <Content />

  <div slot='bottom'>
    <div class='rounded-xl border px-4 py-3 mt-3 sm:py-4 md:mt-6'>
      <ProjectsContents locale={locale} />
    </div>
  </div>
</PageLayout>

<MediumZoom />

<style>
  @media (min-width: 1300px) {
    :global(
      main, .bottom { transform: translateX(7.9rem); }
      #sidebar { overflow: inherit; }
      toc-heading { height: 100%; display: flex; flex-direction: column; }
      toc-heading > ul { overflow-y: scroll; }
    )
    .projects-toc {
      position: fixed;
      top: 0;
      left: -64rem;
      width: 14rem;
      max-width: 15rem;
      margin-top: 0;
      max-height: calc(100vh - 7rem);
      overflow-y: scroll;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-right: 1rem !important;
    }

    .projects-toc::-webkit-scrollbar {
      display: none;
    }
  }
</style>
