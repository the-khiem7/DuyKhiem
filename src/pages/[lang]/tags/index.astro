---
import type { CollectionEntry } from 'astro:content'

import { Button } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { getBlogCollection } from 'astro-pure/server'
import { getLocalizedTagsWithCount } from '@/utils/blog-i18n'
import { getLocaleAlternates, getLocaleStaticPaths, resolveLocaleParam } from '@/utils/i18n'

export const prerender = true

export function getStaticPaths() {
  return getLocaleStaticPaths()
}

const locale = resolveLocaleParam(Astro.params.lang)
const allPosts = (await getBlogCollection()) as CollectionEntry<'blog'>[]
const allTags = getLocalizedTagsWithCount(allPosts, locale)

const meta = {
  description: "A list of all the topics I've written about in my posts",
  title: 'All Tags'
}
---

<PageLayout
  {meta}
  locale={locale}
  canonicalPath={`/${locale}/tags`}
  alternates={getLocaleAlternates('/tags')}
>
  <Button title='Back' href={`/${locale}/blog`} variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>Tags</h1>
    </div>

    <div id='content' class='animate'>
      {
        allTags.length > 0 ? (
          <ul class='flex flex-wrap gap-4'>
            {allTags.map(([tag, val]) => (
              <li>
                <Button
                  href={`/${locale}/tags/${tag}`}
                  variant='pill'
                  class={cn(
                    'items-start gap-x-1',
                    val > 2 ? 'rounded-xl px-3 py-1 text-xl' : val > 1 && 'text-lg'
                  )}
                >
                  {tag}
                  <span class={val > 2 ? 'text-base' : 'text-xs'}>{val}</span>
                </Button>
              </li>
            ))}
          </ul>
        ) : (
          <p>Any tag yet.</p>
        )
      }
    </div>
  </main>
</PageLayout>
