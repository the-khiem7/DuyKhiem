---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button } from 'astro-pure/user'
import PostPreview from '@/components/blog/PostPreview.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'
import { getLocalizedBlogEntries, getLocalizedPostsByTag } from '@/utils/blog-i18n'
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, type SiteLocale } from '@/utils/i18n'
import { getBlogCollection } from 'astro-pure/server'

export const prerender = true

type LocalizedPageData = ReturnType<typeof getLocalizedPostsByTag>[number]

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = (await getBlogCollection()) as CollectionEntry<'blog'>[]
  const tagSet = new Set<string>()

  for (const locale of SUPPORTED_LOCALES) {
    for (const post of getLocalizedBlogEntries(allPosts, locale)) {
      for (const tag of post.entry.data.tags) tagSet.add(tag)
    }
  }

  return SUPPORTED_LOCALES.flatMap((locale) =>
    [...tagSet].flatMap((tag) =>
      paginate(getLocalizedPostsByTag(allPosts, locale, tag), {
        pageSize: config.content.blogPageSize,
        params: { lang: locale, tag }
      })
    )
  )
}

const { page } = Astro.props as { page: Page<LocalizedPageData> }
const { lang = DEFAULT_LOCALE, tag = '' } = Astro.params
const locale = lang as SiteLocale

const meta = {
  description: `View all posts with the tag - ${tag}`,
  title: `Tag: ${tag}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous Tags`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next Tags →`,
      url: page.url.next
    }
  })
}
---

<PageLayout
  {meta}
  locale={locale}
  canonicalPath={page.url.current}
  alternates={SUPPORTED_LOCALES.map((candidate) => ({
    href: `/${candidate}${page.url.current.replace(/^\/(en|vi)/, '')}`,
    hreflang: candidate
  }))}
>
  <Button title='Back' href={`/${locale}/blog`} variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 flex items-end gap-x-2 text-3xl font-medium'>
        Tags:
        <span class='text-2xl'>#{tag}</span>
      </h1>
    </div>

    <section id='content' class='animate' aria-label='Blog post list'>
      <ul class='flex flex-col gap-y-3 text-start'>
        {page.data.map((post) => <PostPreview {post} {locale} detailed />)}
      </ul>
      <Paginator {...paginationProps} />
    </section>
  </main>
</PageLayout>
