---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { Button, Icon } from 'astro-pure/user'
import PostPreview from '@/components/blog/PostPreview.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'
import { getLocalizedBlogEntries, getLocalizedTagsWithCount } from '@/utils/blog-i18n'
import {
  getLocaleAlternates,
  resolveLocaleParam,
  SUPPORTED_LOCALES
} from '@/utils/i18n'
import { getBlogCollection } from 'astro-pure/server'

export const prerender = true

type LocalizedPageData = ReturnType<typeof getLocalizedBlogEntries>[number]

export const getStaticPaths = (async ({ paginate }) => {
  const collections = (await getBlogCollection()) as CollectionEntry<'blog'>[]

  return SUPPORTED_LOCALES.flatMap((locale) =>
    paginate(getLocalizedBlogEntries(collections, locale), {
      pageSize: config.content.blogPageSize,
      params: { lang: locale }
    })
  )
}) satisfies GetStaticPaths

const locale = resolveLocaleParam(Astro.params.lang)
const { page } = Astro.props as { page: Page<LocalizedPageData> }
const allTags = getLocalizedTagsWithCount(
  (await getBlogCollection()) as CollectionEntry<'blog'>[],
  locale
).map(([tag]) => tag)

const meta = {
  description: 'Some posts or archives of my blog',
  title: 'Blog'
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous Posts`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next Posts →`,
      url: page.url.next
    }
  })
}
---

<PageLayout
  {meta}
  locale={locale}
  canonicalPath={page.url.current}
  alternates={getLocaleAlternates(page.url.current)}
>
  <Button title='Back' href={`/${locale}`} variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>Blog</h1>
    </div>
    {
      page.data.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
          <section aria-label='Blog posts list' class='animate' id='content'>
            <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
              <span class='text-muted-foreground'>
                Page {page.currentPage} - Showing {page.data.length} posts
              </span>
              <a aria-label='View all blog by years' href={`/${locale}/archives`} data-astro-prefetch>
                View all posts by years →
              </a>
            </div>
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview {post} {locale} detailed />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </section>

          <aside class='animate' id='sidebar'>
            <h2 class='mb-4 flex items-center text-lg font-medium'>
              <Icon name='tag-2' class='me-2' />
              Tags
            </h2>
            <ul class='text-bgColor flex flex-wrap gap-2'>
              {allTags.slice(0, 20).map((tag) => (
                <li>
                  <Button title={tag} href={`/${locale}/tags/${tag}`} variant='pill' />
                </li>
              ))}
            </ul>
            <span class='mt-4 block sm:text-end'>
              <a aria-label='View all blog categories' href={`/${locale}/tags`} data-astro-prefetch>
                View all →
              </a>
            </span>
          </aside>
        </div>
      )
    }
  </main>
</PageLayout>
