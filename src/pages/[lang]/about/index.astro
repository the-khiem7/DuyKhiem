---
import AboutPage from '@/components/about/AboutPage.astro'
import { getLocaleStaticPaths, resolveLocaleParam } from '@/utils/i18n'

export const prerender = true

export function getStaticPaths() {
  return getLocaleStaticPaths()
}

const locale = resolveLocaleParam(Astro.params.lang)
---

<AboutPage {locale} />
