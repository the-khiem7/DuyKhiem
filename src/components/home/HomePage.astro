---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

import { Quote } from 'astro-pure/advanced'
import { getBlogCollection } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import { getSiteDictionary } from '@/i18n/site'
import PostPreview from '@/components/blog/PostPreview.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'
import { getLocalizedBlogEntries } from '@/utils/blog-i18n'
import { type SiteLocale, withLocalePath } from '@/utils/i18n'

interface Props {
  locale: SiteLocale
}

const { locale } = Astro.props
const dict = getSiteDictionary(locale)

const backend = ['C#', '.NET 8', 'ASP.NET Core', 'REST APIs', 'FastAPI', 'Java']
const systems = ['Microservices', 'Kafka', '.NET Aspire', 'YARP', 'SignalR', 'Workflow Design']
const cloudAndAi = ['AWS', 'Lambda', 'EventBridge', 'PostgreSQL', 'YOLO', 'ClearML']

const MAX_POSTS = 10
const allPosts = (await getBlogCollection()) as CollectionEntry<'blog'>[]
const localizedPosts = getLocalizedBlogEntries(allPosts, locale).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath]) {
  throw new Error(`"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`)
}
---

<PageLayout meta={{ title: dict.home.metaTitle }} highlightColor='#659EB9' locale={locale} canonicalPath={withLocalePath(locale, '/')}>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-50 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <p class='max-w-2xl text-center text-lg text-muted-foreground'>
          {dict.home.hero.description}
        </p>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title={dict.home.hero.location}>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title={dict.home.hero.github} as='a' href='https://github.com/the-khiem7' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label
            title={dict.home.hero.linkedin}
            as='a'
            href='https://www.linkedin.com/in/the-khiem7/'
            target='_blank'
          >
            <Icon name='linkedin' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      <a
        href='/CV_DuyKhiem.pdf'
        download='CV_DuyKhiem.pdf'
        target='_blank'
        data-astro-reload
        class='flex flex-row items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'
      >
        <span class='relative flex items-center justify-center'>
          <span
            class='absolute size-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
          ></span>
          <span class='size-2 rounded-full bg-green-400'></span>
        </span>
        <p class='font-medium text-muted-foreground'>{dict.home.hero.resume}</p>
      </a>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title={dict.home.sections.about}>
        <p class='text-muted-foreground'>{dict.home.about.subtitle}</p>
        {dict.home.about.paragraphs.map((paragraph) => <p class='text-muted-foreground'>{paragraph}</p>)}
        <Button title={dict.home.about.cta} class='w-fit self-end' href={withLocalePath(locale, '/about')} variant='ahead' />
      </Section>

      <Section title={dict.home.sections.experience}>
        <Card
          heading='Amazon Web Services Vietnam'
          subheading='FCAJ Challenger'
          date='Sep 2025 - Now'
          imagePath='/src/assets/experience/aws.jpg'
          altText='Amazon Web Services logo'
          imageMode='background'
          imageBlur={true}
          imageClass='object-cover object-center'
          headingClass='text-2xl'
          subheadingClass='text-lg'
          bodyClass='pt-0'
        >
          <p class='mb-3 -mt-2 text-sm text-muted-foreground sm:text-base'>
            {dict.home.experience.awsLocation}
          </p>
          <ul class='ms-4 list-disc text-muted-foreground'>
            {dict.home.experience.awsBullets.map((item) => <li>{item}</li>)}
          </ul>
        </Card>
        <Card
          heading='FPT Software'
          subheading='.NET Intern'
          date='Dec 2024 - Jun 2025'
          imagePath='/src/assets/experience/fpt-software.jpg'
          altText='FPT Software logo'
          imageMode='background'
          imageBlur={true}
          imageClass='object-cover object-center'
          headingClass='text-2xl'
          subheadingClass='text-lg'
          bodyClass='pt-0'
        >
          <p class='mb-3 -mt-2 text-sm text-muted-foreground sm:text-base'>
            {dict.home.experience.fptLocation}
          </p>
          <ul class='ms-4 list-disc text-muted-foreground'>
            {dict.home.experience.fptBullets.map((item) => <li>{item}</li>)}
          </ul>
        </Card>
      </Section>

      <Section title={dict.home.sections.education}>
        <Card
          heading='FPT University - Ho Chi Minh City Campus'
          subheading='Bachelor of Software Engineering'
          date='Sep 2022 - Jun 2026'
        >
          <p class='text-muted-foreground'>{dict.home.education.body}</p>
        </Card>
      </Section>

      <Section title={dict.home.sections.projects}>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href={withLocalePath(locale, '/projects/snakeaid')}
            heading='SnakeAid'
            subheading={dict.home.projects.cards.snakeaid}
            imagePath='/src/assets/projects/1.avif'
          />
          <ProjectCard
            href={withLocalePath(locale, '/projects/alohamarket')}
            heading='AlohaMarket'
            subheading={dict.home.projects.cards.alohamarket}
            imagePath='/src/assets/projects/2.avif'
          />
          <ProjectCard
            href={withLocalePath(locale, '/projects/ezyfix')}
            heading='EzyFix'
            subheading={dict.home.projects.cards.ezyfix}
            imagePath='/src/assets/projects/3.avif'
          />
          <ProjectCard
            href={withLocalePath(locale, '/projects')}
            heading={dict.home.projects.moreHeading}
            subheading={dict.home.projects.cards.more}
            imagePath='/src/assets/projects/4.avif'
          />
        </div>
      </Section>

      <Section title={dict.home.sections.certifications}>
        <Card
          heading={dict.home.sections.certifications}
          subheading={dict.home.certifications.subtitle}
          date='2024 - 2026'
        >
          <ul class='ms-4 list-disc text-muted-foreground'>
            {dict.home.certifications.items.map((item) => <li>{item}</li>)}
          </ul>
        </Card>
      </Section>

      {
        localizedPosts.length > 0 && (
          <Section title={dict.home.sections.posts}>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {localizedPosts.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} {locale} />
                </li>
              ))}
            </ul>
            <Button title={dict.home.posts.more} class='w-fit self-end' href={withLocalePath(locale, '/blog')} variant='ahead' />
          </Section>
        )
      }

      <Section title={dict.home.sections.skills}>
        <SkillLayout title={dict.home.skills.backend} skills={backend} />
        <SkillLayout title={dict.home.skills.systems} skills={systems} />
        <SkillLayout title={dict.home.skills.cloudAndAi} skills={cloudAndAi} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
