---
import config from '@/site-config'
import { getSiteDictionary } from '@/i18n/site'
import { getCurrentLocale, type SiteLocale, withLocalePath } from '@/utils/i18n'
import { Icon } from 'astro-pure/user'

const locale = (Astro.props.locale as SiteLocale | undefined) ?? getCurrentLocale(Astro.url.pathname)
const dict = getSiteDictionary(locale)

const footerConf = config.footer
const social = { ...(footerConf.social || {}) } as Record<string, { label: string; url: string }>

if (!social.rss) {
  social.rss = {
    label: dict.shared.footer.rssLabel,
    url: withLocalePath(locale, '/rss.xml')
  }
}

const footerLink1 = footerConf.links?.filter(({ pos }) => pos === 1) || []
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-5'>
    <div class='flex items-center gap-y-3 max-sm:flex-col sm:justify-between sm:gap-y-0'>
      <div class='flex items-center gap-x-4 gap-y-2 text-muted-foreground max-sm:flex-col'>
        {
          footerLink1.length > 0 && (
            <div>
              {footerLink1.map(({ title, link, style }, index) => (
                <>
                  <a href={link} target='_blank' class={style}>{title}</a>
                  {index < footerLink1.length - 1 && <span class='mx-1'>•</span>}
                </>
              ))}
            </div>
          )
        }
        <div>
          {config.footer.year}
          {config.author}
          {
            footerConf.links && footerConf.links.length > 0 && (
              <>
                &amp;
                <span>
                  {footerConf.links
                    .filter(({ pos }) => pos === 2)
                    .map(({ title, link, style }) => (
                      <span>
                        <a href={link} target='_blank' class={style}>{title}</a>
                      </span>
                    ))}
                </span>
              </>
            )
          }
        </div>
        {
          footerConf.credits && (
            <span>
              <a href='https://github.com/withastro/astro' target='_blank'>Astro</a>
              &amp;
              <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Pure</a>
              {' '}
              {dict.shared.footer.creditsSuffix}
            </span>
          )
        }
      </div>

      <div class='flex items-center gap-x-4'>
        {
          footerConf.social &&
            Object.entries(social).map(([platform, { label, url }]) => (
              <a href={url} aria-label={label}>
                <Icon name={platform as any} />
              </a>
            ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  footer a {
    color: hsl(var(--foreground) / var(--un-text-opacity, 1));
    text-decoration: underline;
    font-weight: 500;
  }
</style>
