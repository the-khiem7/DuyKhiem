---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import type { HTMLTag, Polymorphic } from 'astro/types'

import { cn } from '../../utils'

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  heading?: string
  subheading?: string
  date?: string
  imagePath?: string
  altText?: string
  imageClass?: string
  imageMode?: 'inline' | 'background'
  imageBlur?: boolean
  overlayClass?: string
  contentClass?: string
  headingClass?: string
  subheadingClass?: string
  dateClass?: string
  bodyClass?: string
  class?: string
}

const {
  as: Tag = 'div',
  class: className,
  href,
  heading,
  subheading,
  date,
  imagePath,
  altText,
  imageClass,
  imageMode = 'inline',
  imageBlur = false,
  overlayClass,
  contentClass,
  headingClass,
  subheadingClass,
  dateClass,
  bodyClass
} = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpeg,jpg,png,gif,avif,webp}'
)
const imageLoader = imagePath ? images[imagePath] : undefined
const hasImage = Boolean(imagePath && imageLoader)
const isBackgroundImage = hasImage && imageMode === 'background'
---

<Tag
  class={cn(
    'not-prose block relative overflow-hidden rounded-2xl border bg-muted px-5 py-4',
    href && 'transition-all hover:border-foreground/25 hover:shadow-sm',
    className
  )}
  href={href}
>
  {
    isBackgroundImage && (
      <>
        <Image
          src={imageLoader!()}
          alt={altText ?? heading ?? ''}
          class={cn(
            'absolute inset-0 h-full w-full object-cover',
            imageBlur ? 'card-bg-blur' : 'card-bg',
            imageClass
          )}
          loading='lazy'
        />
        <div class={cn('card-bg-overlay absolute inset-0', overlayClass)}></div>
      </>
    )
  }
  <div class={cn('card-content relative z-10 flex flex-col gap-y-3', contentClass)}>
    <div class='flex flex-col gap-y-2 md:flex-row md:items-start md:justify-between md:gap-x-5'>
      <div class={cn('flex flex-col gap-y-1', hasImage && imageMode === 'inline' && 'md:flex-row md:items-start md:gap-x-4')}>
        {
          hasImage && imageMode === 'inline' && (
            <Image
              src={imageLoader!()}
              alt={altText ?? heading ?? ''}
              class={cn('h-10 w-auto rounded-lg object-cover', imageClass)}
              loading='lazy'
            />
          )
        }
        <div class='flex flex-col gap-y-1'>
          <h2 class={cn('card-heading text-xl font-semibold leading-tight', headingClass)}>{heading}</h2>
          <p class={cn('card-subheading text-base text-muted-foreground', subheadingClass)}>{subheading}</p>
        </div>
      </div>
      {
        date && (
          <p class={cn('card-date text-sm text-muted-foreground', dateClass)}>
            {date}
          </p>
        )
      }
    </div>
    <div class={cn('card-body', bodyClass)}>
      <slot />
    </div>
  </div>
</Tag>

<style>
  .card-bg {
    opacity: 0.48;
    transform: scale(1.04);
  }

  .card-bg-blur {
    opacity: 0.32;
    transform: scale(1.08);
    filter: blur(2px) saturate(1.02);
  }

  .card-bg-overlay {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.82)),
      linear-gradient(120deg, rgba(255, 255, 255, 0.12), transparent 45%);
  }

  .card-heading {
    text-wrap: balance;
  }

  .card-subheading {
    line-height: 1.45;
  }

  .card-date {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    white-space: nowrap;
    border-radius: 9999px;
    border: 1px solid hsl(var(--border) / 0.8);
    background: hsl(var(--background) / 0.82);
    padding: 0.45rem 0.8rem;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.35) inset;
  }

  :global(.dark) .card-bg {
    opacity: 0.4;
  }

  :global(.dark) .card-bg-blur {
    opacity: 0.36;
  }

  :global(.dark) .card-bg-overlay {
    background:
      linear-gradient(180deg, rgba(10, 14, 22, 0.7), rgba(10, 14, 22, 0.82)),
      linear-gradient(120deg, rgba(12, 18, 30, 0.18), transparent 45%);
  }

  :global(.dark) .card-date {
    border-color: hsl(var(--border) / 0.9);
    background: hsl(var(--background) / 0.58);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset;
  }

  .card-body :global(ul) {
    margin: 0;
    padding-left: 0;
    list-style: none;
  }

  .card-body :global(li) {
    position: relative;
    padding-left: 1.35rem;
    line-height: 1.65;
    color: hsl(var(--foreground) / 0.82);
  }

  .card-body :global(li + li) {
    margin-top: 0.7rem;
  }

  .card-body :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    background: hsl(var(--primary));
    box-shadow: 0 0 0 4px rgba(101, 158, 185, 0.12);
  }

  @media (max-width: 640px) {
    .card-heading {
      font-size: 1.15rem;
    }

    .card-subheading {
      font-size: 0.98rem;
    }
  }
</style>
